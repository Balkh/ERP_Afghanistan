    {
      "id": "design_system_governance",
      "label": "Design System Governance",
      "file_type": "rationale",
      "source_file": "frontend/ENTERPRISE_FRONTEND_FORENSIC_AUDIT.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Design system is well-architected with comprehensive tokens and enterprise components but catastrophically under-adopted (~50-70% bypass rate). Governance failure is adoption failure, not design failure."
    },
    {
      "id": "component_adoption_failure",
      "label": "Component Adoption Failure",
      "file_type": "rationale",
      "source_file": "frontend/ENTERPRISE_FRONTEND_FORENSIC_AUDIT.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "71% of dialogs, 55% of tables, 95% of forms, and 80+ notification instances bypass the design system. Two parallel implementation paths exist."
    },
    {
      "id": "theme_engine_registration_failure",
      "label": "ThemeEngine Registration Failure",
      "file_type": "rationale",
      "source_file": "frontend/ENTERPRISE_FRONTEND_FORENSIC_AUDIT.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Only 3 widgets register with ThemeEngine for theme switching. ~40+ screens do not register, meaning runtime theme switching will not update these screens."
    },
    {
      "id": "information_architecture_chaos",
      "label": "Information Architecture Chaos",
      "file_type": "rationale",
      "source_file": "frontend/ENTERPRISE_FRONTEND_FORENSIC_AUDIT.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "67 sidebar entries, 12 groups, 3 levels of nested tabs, duplicate implementations, enterprise debugging tools visible to pharmacy staff, 7 orphaned screens."
    },
    {
      "id": "phased_enforcement_model",
      "label": "Phased Enforcement Model",
      "file_type": "rationale",
      "source_file": "frontend/.github/workflows/design_enforcement_phased.yml",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Three-phase CI enforcement: Phase 1 (Observability, continue-on-error), Phase 2 (Soft, blocking), Phase 3 (Hard, blocking). Default to Phase 2 for both main and develop branches."
    },
